    "@prisma/client": "^5.16.2",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "winston": "^3.13.1",
    "nest-winston": "^1.9.7",
    "nodemailer": "^6.9.15",
    "uuid": "^10.0.0"
