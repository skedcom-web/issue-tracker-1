// vThink Project & Issue Tracker — Prisma Schema
// PostgreSQL + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ─────────────────────────────────────────────────────────

enum Role {
  Admin
  Manager
  Developer
  QA
  Reporter
}

enum IssueStatus {
  Open
  InProgress
  InReview
  Resolved
  Closed
  Reopened
}

enum IssuePriority {
  Critical
  High
  Medium
  Low
}

enum IssueSeverity {
  Critical
  Blocker
  Major
  Minor
}

enum IssueType {
  Bug
  Task
  FeatureRequest
  Improvement
}

enum IssueEnvironment {
  Dev
  QA
  UAT
  Production
}

enum ProjectStatus {
  Active
  Ended
}

// ── TABLES ────────────────────────────────────────────────────────

model Employee {
  id             String   @id @default(uuid())
  employeeNumber String   @unique
  employeeName   String
  designation    String?
  email          String?
  managerEmpNo   String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Reverse relation
  userAccount User?

  @@index([employeeNumber])
  @@index([active])
  @@map("employees")
}

model User {
  id                 String   @id @default(uuid())
  name               String
  email              String   @unique
  password           String
  role               Role     @default(Reporter)
  department         String?
  employeeNumber     String?
  active             Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Password reset
  resetToken       String?
  resetTokenExpiry DateTime?

  // Link to employee record
  employeeId String?   @unique
  employee   Employee? @relation(fields: [employeeId], references: [id])

  // Authored issues / comments
  reportedIssues Issue[]       @relation("Reporter")
  comments       Comment[]
  activityLogs   ActivityLog[]

  @@index([email])
  @@index([role])
  @@index([active])
  @@map("users")
}

model Project {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  department  String?
  lead        String?
  startDate   DateTime?
  endDate     DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  issues Issue[]

  @@index([name])
  @@map("projects")
}

model Issue {
  id               Int               @id @default(autoincrement())
  defectNo         String            @unique
  title            String
  description      String
  type             IssueType         @default(Bug)
  priority         IssuePriority
  severity         IssueSeverity     @default(Major)
  status           IssueStatus       @default(Open)
  environment      IssueEnvironment?
  module           String?
  dueDate          DateTime?
  resolution       String?
  stepsToReproduce String?
  expectedResult   String?
  actualResult     String?
  fileName         String?
  fileUrl          String?
  reopenCount      Int               @default(0)
  resolvedAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  // Relations
  projectId Int
  project   Project @relation(fields: [projectId], references: [id])

  reporterId String?
  reporter   User?   @relation("Reporter", fields: [reporterId], references: [id])

  assigneeId      String? // employee record id
  contactPersonId String? // employee to contact for details

  comments     Comment[]
  activityLogs ActivityLog[]

  @@index([status])
  @@index([priority])
  @@index([projectId])
  @@index([assigneeId])
  @@index([reporterId])
  @@index([createdAt])
  @@map("issues")
}

model Comment {
  id        Int      @id @default(autoincrement())
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issueId Int
  issue   Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  authorId String
  author   User   @relation(fields: [authorId], references: [id])

  @@index([issueId])
  @@map("comments")
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  type      String
  message   String
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  issueId Int?
  issue   Issue? @relation(fields: [issueId], references: [id])

  projectId Int?

  @@index([createdAt])
  @@index([userId])
  @@map("activity_logs")
}

model ProjectCounter {
  projectId Int @id
  counter   Int @default(0)

  @@map("project_counters")
}
