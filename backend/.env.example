# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/vthink_tracker?schema=public"

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="24h"

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# ── App ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
