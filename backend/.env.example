# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/vthink_tracker?schema=public"

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="24h"

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# ── App ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Frontend base URL (used in issue notification emails — “Open issue” links)
APP_URL="http://localhost:5173"

# ── Email (SMTP) — welcome, password reset, issue notifications ──
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="vThink Tracker <noreply@example.com>"
